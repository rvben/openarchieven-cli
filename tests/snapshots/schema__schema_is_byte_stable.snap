---
source: tests/schema.rs
expression: s
---
{
  "clispec": "0.2",
  "name": "openarchieven",
  "version": "[version]",
  "base_url": "https://api.openarchieven.nl/1.1",
  "rate_limit": {
    "requests_per_second": 4,
    "scope": "per_ip"
  },
  "output_formats": [
    "json",
    "ndjson",
    "table",
    "text",
    "markdown"
  ],
  "global_args": [
    {
      "name": "--output",
      "short": "-o",
      "type": "string",
      "required": false,
      "description": "Output format: json, ndjson, table, text, markdown"
    },
    {
      "name": "--pretty",
      "short": null,
      "type": "bool",
      "required": false,
      "description": "Pretty-print JSON output"
    },
    {
      "name": "--quiet",
      "short": "-q",
      "type": "bool",
      "required": false,
      "description": "Suppress stderr progress output"
    },
    {
      "name": "--no-color",
      "short": null,
      "type": "bool",
      "required": false,
      "description": "Disable ANSI colors"
    },
    {
      "name": "--no-cache",
      "short": null,
      "type": "bool",
      "required": false,
      "description": "Bypass cache read and write for this invocation"
    },
    {
      "name": "--refresh",
      "short": null,
      "type": "bool",
      "required": false,
      "description": "Bypass cache read; still write"
    },
    {
      "name": "--cache-ttl",
      "short": null,
      "type": "string",
      "required": false,
      "description": "Override cache TTL (e.g. 1h, inf, 0)"
    },
    {
      "name": "--cache-dir",
      "short": null,
      "type": "string",
      "required": false,
      "description": "Override cache directory"
    },
    {
      "name": "--fields",
      "short": null,
      "type": "string",
      "required": false,
      "description": "Top-level field projection (comma-separated)"
    },
    {
      "name": "--limit",
      "short": null,
      "type": "integer",
      "required": false,
      "description": "Pagination limit where supported"
    },
    {
      "name": "--offset",
      "short": null,
      "type": "integer",
      "required": false,
      "description": "Pagination offset where supported"
    },
    {
      "name": "--lang",
      "short": null,
      "type": "string",
      "required": false,
      "description": "Response language (default: nl)"
    },
    {
      "name": "--timeout",
      "short": null,
      "type": "string",
      "required": false,
      "description": "Per-request timeout (e.g. 30s, 1m, 500ms)"
    }
  ],
  "env_vars": [
    {
      "name": "OPENARCHIEVEN_BASE_URL",
      "effect": "Override API base URL (test use)"
    },
    {
      "name": "OPENARCHIEVEN_OUTPUT",
      "effect": "Default output format if --output not given"
    },
    {
      "name": "OPENARCHIEVEN_RATE_LIMIT",
      "effect": "Override 4 req/sec local limiter (test use)"
    },
    {
      "name": "OPENARCHIEVEN_CACHE_DIR",
      "effect": "Override cache directory"
    },
    {
      "name": "OPENARCHIEVEN_CACHE_DISABLE",
      "effect": "When 1, disable cache for the process"
    },
    {
      "name": "NO_COLOR",
      "effect": "Disable colored stderr output"
    }
  ],
  "cache": {
    "default_dir_template": "$XDG_CACHE_HOME/openarchieven (Linux), ~/Library/Caches/openarchieven (macOS)",
    "file_permissions": "0600",
    "dir_permissions": "0700"
  },
  "commands": [
    {
      "name": "archives",
      "description": "List all participating archives.",
      "mutating": false,
      "response_shape": "list",
      "paginated": false,
      "cache_ttl_seconds": 604800,
      "cache_ttl_strategy": "fixed",
      "args": [],
      "output_fields": [
        {
          "name": "items",
          "type": "array<archive>",
          "description": "Archive objects returned by the API"
        },
        {
          "name": "total",
          "type": "integer",
          "description": "Total number of archives in the response"
        },
        {
          "name": "limit",
          "type": "null",
          "description": "Always null; this command is non-paginated"
        },
        {
          "name": "offset",
          "type": "null",
          "description": "Always null; this command is non-paginated"
        },
        {
          "name": "paginated",
          "type": "boolean",
          "description": "Always false for this command"
        }
      ]
    },
    {
      "name": "search",
      "description": "Free-text record search across all archives.",
      "mutating": false,
      "response_shape": "list",
      "paginated": true,
      "cache_ttl_seconds": 21600,
      "cache_ttl_strategy": "fixed",
      "args": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "positional": true,
          "description": "Name to search for across all archives"
        },
        {
          "name": "--archive",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Filter by archive code"
        },
        {
          "name": "--source-type",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Filter by source type"
        },
        {
          "name": "--event-place",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Filter by place where the event occurred"
        },
        {
          "name": "--birth-place",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Filter by place of birth"
        },
        {
          "name": "--relation-type",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Filter by relation type of the person to the record"
        },
        {
          "name": "--country",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Filter by country code"
        },
        {
          "name": "--sort",
          "type": "integer",
          "required": false,
          "positional": false,
          "description": "Sort order integer (see enum values); default 1 = name ascending",
          "default": 1,
          "enum": [
            {
              "description": "Sort by source descending",
              "label": "source_desc",
              "value": -6
            },
            {
              "description": "Sort by place descending",
              "label": "place_desc",
              "value": -5
            },
            {
              "description": "Sort by date descending",
              "label": "date_desc",
              "value": -4
            },
            {
              "description": "Sort by event type descending",
              "label": "event_desc",
              "value": -3
            },
            {
              "description": "Sort by role descending",
              "label": "role_desc",
              "value": -2
            },
            {
              "description": "Sort by name descending",
              "label": "name_desc",
              "value": -1
            },
            {
              "description": "Sort by name ascending (default)",
              "label": "name_asc",
              "value": 1
            },
            {
              "description": "Sort by role ascending",
              "label": "role_asc",
              "value": 2
            },
            {
              "description": "Sort by event type ascending",
              "label": "event_asc",
              "value": 3
            },
            {
              "description": "Sort by date ascending",
              "label": "date_asc",
              "value": 4
            },
            {
              "description": "Sort by place ascending",
              "label": "place_asc",
              "value": 5
            },
            {
              "description": "Sort by source ascending",
              "label": "source_asc",
              "value": 6
            }
          ]
        },
        {
          "name": "--limit",
          "type": "integer",
          "required": false,
          "positional": false,
          "description": "Maximum number of results per page (1-100)",
          "default": 10,
          "max": 100
        },
        {
          "name": "--offset",
          "type": "integer",
          "required": false,
          "positional": false,
          "description": "Zero-based index of the first result to return",
          "default": 0
        },
        {
          "name": "--lang",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Response language for labels and descriptions",
          "default": "nl",
          "enum": [
            "nl",
            "en"
          ]
        }
      ],
      "output_fields": [
        {
          "name": "items",
          "type": "array<record>",
          "description": "Matched record objects from /response/docs"
        },
        {
          "name": "total",
          "type": "integer | null",
          "description": "Total hit count from /response/numFound; null if unavailable"
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Maximum number of items returned in this page"
        },
        {
          "name": "offset",
          "type": "integer",
          "description": "Zero-based index of the first item in this page"
        },
        {
          "name": "paginated",
          "type": "boolean",
          "description": "Always true; this command supports pagination"
        }
      ]
    },
    {
      "name": "show",
      "description": "Fetch a single record by archive code and identifier.",
      "mutating": false,
      "response_shape": "single-nested",
      "paginated": false,
      "cache_ttl_seconds": 86400,
      "cache_ttl_strategy": "fixed",
      "args": [
        {
          "name": "archive",
          "type": "string",
          "required": true,
          "positional": true,
          "description": "Archive code identifying the holding institution"
        },
        {
          "name": "identifier",
          "type": "string",
          "required": true,
          "positional": true,
          "description": "Record identifier within the archive"
        },
        {
          "name": "--lang",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Response language for labels and descriptions",
          "default": "nl",
          "enum": [
            "nl",
            "en"
          ]
        }
      ],
      "output_fields": []
    },
    {
      "name": "match",
      "description": "Match a record by name and birth year (probabilistic linkage).",
      "mutating": false,
      "response_shape": "list",
      "paginated": false,
      "cache_ttl_seconds": 21600,
      "cache_ttl_strategy": "fixed",
      "args": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "positional": true,
          "description": "Full name of the person to match"
        },
        {
          "name": "birthyear",
          "type": "integer",
          "required": true,
          "positional": true,
          "description": "Birth year used together with name for probabilistic matching"
        },
        {
          "name": "--lang",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Response language for labels and descriptions",
          "default": "nl",
          "enum": [
            "nl",
            "en"
          ]
        }
      ],
      "output_fields": [
        {
          "name": "items",
          "type": "array<record>",
          "description": "Matched record objects from /response/docs"
        },
        {
          "name": "total",
          "type": "integer | null",
          "description": "Total match count from /response/numFound; null if unavailable"
        },
        {
          "name": "paginated",
          "type": "boolean",
          "description": "Always false; this command is non-paginated"
        }
      ]
    },
    {
      "name": "births",
      "description": "Birth-event records by name with optional location/year filters.",
      "mutating": false,
      "response_shape": "list",
      "paginated": true,
      "cache_ttl_seconds": 21600,
      "cache_ttl_strategy": "fixed",
      "args": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "positional": true,
          "description": "Name of the person to search for in birth records"
        },
        {
          "name": "--event-year",
          "type": "integer",
          "required": false,
          "positional": false,
          "description": "Filter by year of birth event; client-side post-filtered"
        },
        {
          "name": "--event-place",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Filter by place of birth event"
        },
        {
          "name": "--event-province",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Filter by province of birth event (births only)"
        },
        {
          "name": "--limit",
          "type": "integer",
          "required": false,
          "positional": false,
          "description": "Maximum number of results per page (1-100)",
          "default": 10,
          "max": 100
        },
        {
          "name": "--offset",
          "type": "integer",
          "required": false,
          "positional": false,
          "description": "Zero-based index of the first result to return",
          "default": 0
        }
      ],
      "output_fields": [
        {
          "name": "items",
          "type": "array<record>",
          "description": "Birth record objects from /response/docs"
        },
        {
          "name": "total",
          "type": "integer | null",
          "description": "Total hit count from /response/numFound; null if unavailable"
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Maximum number of items returned in this page"
        },
        {
          "name": "offset",
          "type": "integer",
          "description": "Zero-based index of the first item in this page"
        },
        {
          "name": "paginated",
          "type": "boolean",
          "description": "Always true; this command supports pagination"
        }
      ]
    },
    {
      "name": "deaths",
      "description": "Death-event records by name.",
      "mutating": false,
      "response_shape": "list",
      "paginated": true,
      "cache_ttl_seconds": 21600,
      "cache_ttl_strategy": "fixed",
      "args": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "positional": true,
          "description": "Name of the person to search for in death records"
        },
        {
          "name": "--event-year",
          "type": "integer",
          "required": false,
          "positional": false,
          "description": "Filter by year of death event; client-side post-filtered"
        },
        {
          "name": "--event-place",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Filter by place of death event"
        },
        {
          "name": "--limit",
          "type": "integer",
          "required": false,
          "positional": false,
          "description": "Maximum number of results per page (1-100)",
          "default": 10,
