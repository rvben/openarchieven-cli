        },
        {
          "name": "total",
          "type": "integer | null",
          "description": "Total hit count from /response/numFound; null if unavailable"
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Maximum number of items returned in this page"
        },
        {
          "name": "offset",
          "type": "integer",
          "description": "Zero-based index of the first item in this page"
        },
        {
          "name": "paginated",
          "type": "boolean",
          "description": "Always true; this command supports pagination"
        }
      ]
    },
    {
      "name": "marriages",
      "description": "Marriage-event records by both partners' names.",
      "mutating": false,
      "response_shape": "list",
      "paginated": true,
      "cache_ttl_seconds": 21600,
      "cache_ttl_strategy": "fixed",
      "args": [
        {
          "name": "name1",
          "type": "string",
          "required": true,
          "positional": true,
          "description": "Name of the first partner"
        },
        {
          "name": "name2",
          "type": "string",
          "required": true,
          "positional": true,
          "description": "Name of the second partner"
        },
        {
          "name": "--event-year",
          "type": "integer",
          "required": false,
          "positional": false,
          "description": "Filter by year of marriage event; client-side post-filtered"
        },
        {
          "name": "--event-place",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Filter by place of marriage event"
        },
        {
          "name": "--limit",
          "type": "integer",
          "required": false,
          "positional": false,
          "description": "Maximum number of results per page (1-100)",
          "default": 10,
          "max": 100
        },
        {
          "name": "--offset",
          "type": "integer",
          "required": false,
          "positional": false,
          "description": "Zero-based index of the first result to return",
          "default": 0
        }
      ],
      "output_fields": [
        {
          "name": "items",
          "type": "array<record>",
          "description": "Marriage record objects from /response/docs"
        },
