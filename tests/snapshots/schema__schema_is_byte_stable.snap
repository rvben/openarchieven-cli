        },
        {
          "name": "paginated",
          "type": "boolean",
          "description": "Always true; this command supports pagination"
        }
      ]
    },
    {
      "name": "yearsago",
      "description": "Records from N years ago today (date-dependent).",
      "mutating": false,
      "response_shape": "list",
      "paginated": false,
      "cache_ttl_seconds": null,
      "cache_ttl_strategy": "until_midnight",
      "args": [
        {
          "name": "years",
          "type": "integer",
          "required": true,
          "positional": true,
          "description": "Number of years to look back from today",
          "min": 0
        },
        {
          "name": "--limit",
          "type": "integer",
          "required": false,
          "positional": false,
          "description": "Maximum number of results to return (1-100)",
          "default": 10,
          "min": 1,
          "max": 100
        }
      ],
      "output_fields": [
        {
          "name": "items",
          "type": "array<record>",
          "description": "Records from exactly N years ago today, from /response/docs"
        },
        {
          "name": "total",
          "type": "integer",
          "description": "Number of items in this response (not a server-side total)"
        },
        {
          "name": "paginated",
          "type": "boolean",
          "description": "Always false; this command uses limit-only pagination"
        }
      ]
    },
    {
      "name": "census",
      "description": "Census records by place or gg URI.",
      "mutating": false,
      "response_shape": "single-nested",
      "paginated": false,
      "cache_ttl_seconds": null,
      "cache_ttl_strategy": "never",
      "args": [
        {
          "name": "--year",
          "type": "integer",
          "required": true,
          "positional": false,
          "description": "Census year to retrieve data for"
        },
        {
          "name": "--place",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Place name; mutually exclusive with --gg-uri"
        },
        {
          "name": "--gg-uri",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Gemeentegeschiedenis URI for the place; mutually exclusive with --place"
        },
        {
          "name": "--province",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Province filter to narrow census results"
        },
        {
          "name": "--richness",
          "type": "integer",
          "required": false,
          "positional": false,
          "description": "Level of detail to include: 1=basic, 2=full, 3=aggregated",
          "min": 1,
          "max": 3,
          "enum": [
            {
              "description": "Basic information and population number",
              "label": "basic",
              "value": 1
            },
            {
              "description": "Like basic, plus all available census data",
              "label": "full",
              "value": 2
            },
            {
              "description": "Like full, plus aggregated data about provinces",
              "label": "aggregated",
              "value": 3
            }
          ]
        }
      ],
      "output_fields": []
    },
    {
      "name": "weather",
      "description": "Historical weather observations for a date and coordinate.",
      "mutating": false,
      "response_shape": "list",
      "paginated": false,
      "cache_ttl_seconds": null,
      "cache_ttl_strategy": "never",
      "args": [
        {
          "name": "--date",
          "type": "string",
          "required": true,
          "positional": false,
          "description": "Date in YYYY-MM-DD format for which to retrieve weather observations"
        },
        {
          "name": "--longitude",
          "type": "number",
          "required": true,
          "positional": false,
          "description": "Decimal longitude of the location"
        },
        {
          "name": "--latitude",
          "type": "number",
          "required": true,
          "positional": false,
          "description": "Decimal latitude of the location"
        },
        {
          "name": "--lang",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Response language for labels and descriptions",
          "default": "nl",
          "enum": [
            "nl",
            "en"
          ]
        }
      ],
      "output_fields": [
        {
          "name": "items",
          "type": "array<observation>",
          "description": "Weather observation objects for the requested date and coordinate"
        },
        {
          "name": "total",
          "type": "integer",
          "description": "Number of observation objects in this response"
        },
        {
          "name": "limit",
          "type": "null",
          "description": "Always null; this command is non-paginated"
        },
        {
          "name": "offset",
          "type": "null",
          "description": "Always null; this command is non-paginated"
        },
        {
          "name": "paginated",
          "type": "boolean",
          "description": "Always false for this command"
        }
      ]
    },
    {
      "name": "stats records",
      "description": "Per-archive record counts.",
      "mutating": false,
      "response_shape": "list",
      "paginated": false,
      "cache_ttl_seconds": 86400,
      "cache_ttl_strategy": "fixed",
      "args": [
        {
          "name": "--archive",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Filter results to a specific archive code"
        }
      ],
      "output_fields": [
        {
          "name": "items",
          "type": "array<row>",
          "description": "Per-archive record count rows"
        },
        {
          "name": "total",
          "type": "integer",
          "description": "Number of rows returned"
        },
        {
          "name": "paginated",
          "type": "boolean",
          "description": "Always false; this command is non-paginated"
        }
      ]
    },
    {
      "name": "stats sources",
      "description": "Per-archive source-type counts.",
      "mutating": false,
      "response_shape": "list",
      "paginated": false,
      "cache_ttl_seconds": 86400,
      "cache_ttl_strategy": "fixed",
      "args": [
        {
          "name": "--archive",
          "type": "string",
          "required": false,
          "positional": false,
          "description": "Filter results to a specific archive code"
        }
      ],
      "output_fields": [
        {
          "name": "items",
          "type": "array<row>",
          "description": "Per-archive source-type count rows"
        },
        {
          "name": "total",
          "type": "integer",
          "description": "Number of rows returned"
