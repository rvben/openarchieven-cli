---
{
  "name": "openarchieven",
  "version": "[version]",
  "base_url": "https://api.openarchieven.nl/1.1",
  "rate_limit": {
    "requests_per_second": 4,
    "scope": "per_ip"
  },
  "output_formats": [
    "json",
    "table",
    "markdown"
  ],
  "env_vars": [
    {
      "name": "OPENARCHIEVEN_BASE_URL",
      "effect": "Override API base URL (test use)"
    },
    {
      "name": "OPENARCHIEVEN_OUTPUT",
      "effect": "Default output format if --output not given"
    },
    {
      "name": "OPENARCHIEVEN_RATE_LIMIT",
      "effect": "Override 4 req/sec local limiter (test use)"
    },
    {
      "name": "OPENARCHIEVEN_CACHE_DIR",
      "effect": "Override cache directory"
    },
    {
      "name": "OPENARCHIEVEN_CACHE_DISABLE",
      "effect": "When 1, disable cache for the process"
    },
    {
      "name": "NO_COLOR",
      "effect": "Disable colored stderr output"
    }
  ],
  "cache": {
    "default_dir_template": "$XDG_CACHE_HOME/openarchieven (Linux), ~/Library/Caches/openarchieven (macOS)",
    "file_permissions": "0600",
    "dir_permissions": "0700"
  },
  "commands": [
    {
      "name": "search",
      "description": "Free-text record search across all archives.",
      "mutating": false,
      "response_shape": "list",
      "paginated": true,
      "cache_ttl_seconds": 21600,
      "cache_ttl_strategy": "fixed",
      "args": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "positional": true
        },
        {
          "name": "--archive",
          "type": "string",
          "required": false,
          "positional": false
        },
        {
          "name": "--source-type",
          "type": "string",
          "required": false,
          "positional": false
        },
        {
          "name": "--event-place",
          "type": "string",
          "required": false,
          "positional": false
        },
        {
          "name": "--birth-place",
          "type": "string",
          "required": false,
          "positional": false
        },
        {
          "name": "--relation-type",
          "type": "string",
          "required": false,
          "positional": false
        },
        {
          "name": "--country",
          "type": "string",
          "required": false,
          "positional": false
        },
        {
          "name": "--sort",
          "type": "integer",
          "required": false,
          "positional": false,
          "default": 1,
          "enum": [
            {
              "description": "Sort by source descending",
              "label": "source_desc",
              "value": -6
            },
            {
              "description": "Sort by place descending",
              "label": "place_desc",
              "value": -5
            },
            {
              "description": "Sort by date descending",
              "label": "date_desc",
              "value": -4
            },
            {
              "description": "Sort by event type descending",
              "label": "event_desc",
              "value": -3
            },
            {
              "description": "Sort by role descending",
              "label": "role_desc",
              "value": -2
            },
            {
              "description": "Sort by name descending",
              "label": "name_desc",
              "value": -1
            },
            {
              "description": "Sort by name ascending (default)",
              "label": "name_asc",
              "value": 1
            },
            {
              "description": "Sort by role ascending",
              "label": "role_asc",
              "value": 2
            },
            {
              "description": "Sort by event type ascending",
              "label": "event_asc",
              "value": 3
            },
            {
              "description": "Sort by date ascending",
              "label": "date_asc",
              "value": 4
            },
            {
              "description": "Sort by place ascending",
              "label": "place_asc",
              "value": 5
            },
            {
              "description": "Sort by source ascending",
              "label": "source_asc",
              "value": 6
            }
          ]
        },
        {
          "name": "--limit",
          "type": "integer",
          "required": false,
          "positional": false,
          "default": 10,
          "max": 100
        },
        {
          "name": "--offset",
          "type": "integer",
          "required": false,
          "positional": false,
          "default": 0
        },
        {
          "name": "--lang",
          "type": "string",
          "required": false,
          "positional": false,
          "default": "nl",
          "enum": [
            "nl",
            "en"
          ]
        }
      ],
      "output_fields": [
        {
          "name": "items",
          "type": "array<record>"
        },
        {
          "name": "total",
          "type": "integer | null"
        },
        {
          "name": "limit",
          "type": "integer"
        },
        {
          "name": "offset",
          "type": "integer"
        },
        {
          "name": "paginated",
          "type": "boolean"
        }
      ]
    },
